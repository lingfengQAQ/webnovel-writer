{
  "description": "Monitor Claude Code lifecycle and tool-call events for the webnovel-writer plugin.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "shell": "python3",
            "command": "import os; exec(open(os.path.join(os.environ['CLAUDE_PLUGIN_ROOT'],'hooks','dispatch.py')).read())"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "shell": "python3",
            "command": "import os; exec(open(os.path.join(os.environ['CLAUDE_PLUGIN_ROOT'],'hooks','dispatch.py')).read())"
          }
        ]
      }
