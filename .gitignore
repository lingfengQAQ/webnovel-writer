# Python
__pycache__/
*.py[cod]
*.so
*.egg
*.egg-info/
dist/
build/

# Backup files (Git is the backup)
*.backup
*.backup_*
*.bak
*~

# Temporary files
*.tmp
*.log
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Claude Code settings (contains command history)
.claude/settings.local.json

# Testing artifacts
test-security-project/
.pytest_cache/
.coverage
htmlcov/

# webnovel-writer runtime data (tracked separately)
.webnovel/context_cache.json
.webnovel/workflow_state.json
.webnovel/index.db

# Test and example projects (don't commit user data)
backup_webnovel_*/
webnovel-project/
crucible-temp/
test_*.py
test_*.md
*沙盘推演*.md

# Don't ignore important .webnovel files
!.webnovel/state.json
!.webnovel/archive/
!.webnovel/backups/
