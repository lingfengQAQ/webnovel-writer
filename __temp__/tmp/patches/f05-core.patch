+READ_ERROR_RESPONSES = {
+    404: {"model": ApiErrorResponse, "description": "Resource not found."},
+    409: {"model": ApiErrorResponse, "description": "Conflict."},
+    500: {"model": ApiErrorResponse, "description": "Internal server error."},
